# SERVER
PORT=3000

# DATABASE
DATABASE_URL=your_mongodb_connection_string

# 🔥 ETHEREUM (ALCHEMY - REQUIRED)
ALCHEMY_HTTP=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_WS=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# 🔥 SXP TOKEN CONTRACT (ERC-20)
SXP_ETH_CONTRACT=0x8ce9137d39326ad0cd6491fb5cc0cba0e089b6a9

# 🔐 SECURITY
JWT_SECRET=replace_with_long_random_secure_string

# 🌍 OPTIONAL (FOR FRONTEND)
ALLOWED_ORIGINS=https://your-frontend-domain.com

# ⛽ OPTIONAL (FOR FUTURE WITHDRAWALS)
SYSTEM_MASTER_WALLET_PRIVATE_KEY=your_private_key_here
